# policy.bird.j2
# Dynamic policy sets generated from router configuration.

# ---------------------------------------------------------------------------
# Blacklist Sets
# ---------------------------------------------------------------------------

# AS Path Blacklist (Integer Set) — includes expanded blacklist as-set members
define autogen_as_blacklist = [
{% for asn in (cs.config.blacklist | default({}))['_expanded_asn'] | default([]) %}
  {{ asn }}{{ "," if not loop.last }}
{% endfor %}
];

# IPv4 Prefix Blacklist
define autogen_prefix_blacklist = [
{% for pfx in (cs.config.blacklist | default({})).prefix4 | default([]) %}
  {{ pfx }}{{ "," if not loop.last }}
{% endfor %}
];

# IPv6 Prefix Blacklist
define autogen_prefix6_blacklist = [
{% for pfx in (cs.config.blacklist | default({})).prefix6 | default([]) %}
  {{ pfx }}{{ "," if not loop.last }}
{% endfor %}
];

# ---------------------------------------------------------------------------
# Local ASN Prefix Sets
# ---------------------------------------------------------------------------

# Local-ASN prefix sets (used by direct/kernel import filters)
define autogen_local_asn_prefix4 = [
{% for pfx in router_config.local_asn_prefix4 | default([]) %}
  {{ pfx }}{{ "," if not loop.last }}
{% endfor %}
];

define autogen_local_asn_prefix6 = [
{% for pfx in router_config.local_asn_prefix6 | default([]) %}
  {{ pfx }}{{ "," if not loop.last }}
{% endfor %}
];

# ---------------------------------------------------------------------------
# Custom Defines (user-defined prefix-sets and as-sets)
# ---------------------------------------------------------------------------

{% if router_config.defines %}
{% for name, pfxs in router_config.defines.get('prefix-sets', {}).items() %}
define {{ name | lower | replace('-', '_') }} = [
{% for pfx in pfxs %}
  {{ pfx }}{{ "," if not loop.last }}
{% endfor %}
];
{% endfor %}

{% for name, asns in router_config.defines.get('as-sets', {}).items() %}
define {{ name | lower | replace('-', '_') }} = [
{% for asn in asns %}
  {{ asn }}{{ "," if not loop.last }}
{% endfor %}
];
{% endfor %}
{% endif %}
