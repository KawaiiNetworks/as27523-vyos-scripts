# neighbors.bird.j2
# Per-session BGP inbound/outbound filters and protocol instances.
{# A reject that, when record_filtered is on, logs the dropped route (reason +
   session identity + prefix + as-path) before discarding it. Emitted inline
   after `then`, so it expands to a `{ ...; reject; }` block. #}
{% macro filtered_reject(reason, ntype, asn, nid, neighbor) -%}
{ if record_filtered then print "IMPORT-FILTERED {{ reason }} {{ ntype }} as{{ asn }} nid{{ nid }}{% if neighbor.description %} {{ neighbor.description | replace('"', "'") }}{% endif %}: ", net, " path ", bgp_path; reject; }
{%- endmacro %}
{# Like filtered_reject, but the reason is a BIRD string variable (e.g. the value
   returned by autogen_filter_ebgp) rather than a compile-time literal. `tag`
   distinguishes the direction (IMPORT-FILTERED vs EXPORT-FILTERED). #}
{% macro filtered_reject_var(reason_var, ntype, asn, nid, neighbor, tag='IMPORT-FILTERED') -%}
{ if record_filtered then print "{{ tag }} ", {{ reason_var }}, " {{ ntype }} as{{ asn }} nid{{ nid }}{% if neighbor.description %} {{ neighbor.description | replace('"', "'") }}{% endif %}: ", net, " path ", bgp_path; reject; }
{%- endmacro %}
{% macro render_neighbor_filters(ntype, neighbor) %}
{% set asn = neighbor._asn %}
{% set nid = neighbor.nid %}
{% set filter_prefix = neighbor._filter_prefix %}
{% set irr_cone = neighbor._irr_cone %}
{# One skeleton for every _in filter — only the contents vary, so the Jinja
   stays flat (no indent juggling; BIRD optimizes the constant branches):
     if (<extra-import-prefixes, or false>) then { }   # match => skip all filtering
     else { <prefix: cone/prefix-list>; if !blackhole_triggered then { <as-path>; <ebgp_in> } }
   extra-import skips everything; a blackhole (blackhole_triggered) keeps only the prefix check;
   both still reach the attr region, where a blackhole is sent to discard. #}

# ---------------------------------------------------------------------------
# Filter: AS{{ asn }} ({{ ntype }}) - {{ neighbor._desc_filter }}
# ---------------------------------------------------------------------------
filter {{ filter_prefix }}_in {
  bool blackhole_triggered = check_blackhole();
{% if not neighbor._no_in_filter and ntype != 'IBGP' %}
  string ebgp_reject_reason = "";
{% endif %}
  # pre import filter
{% if neighbor['pre-import-filter'] %}
{{ neighbor['pre-import-filter'] | trim | indent(2, true) }}
{% endif %}

  # import filter
  if ({{ neighbor._extra_import_expr }}) then { }
  else {
{% if irr_cone %}
    if net.type = NET_IP4 && !(net ~ autogen_as{{ asn }}_cone_prefix4) then {{ filtered_reject('irr-cone', ntype, asn, nid, neighbor) }}
    if net.type = NET_IP6 && !(net ~ autogen_as{{ asn }}_cone_prefix6) then {{ filtered_reject('irr-cone', ntype, asn, nid, neighbor) }}
{% endif %}
{% if neighbor['_has_prefix_list'] %}
{% if neighbor['_prefix4'] | length %}
    if net.type = NET_IP4 && !(net ~ [ {{ neighbor['_prefix4'] | join(', ') }} ]) then {{ filtered_reject('prefix-list', ntype, asn, nid, neighbor) }}
{% else %}
    if net.type = NET_IP4 then {{ filtered_reject('prefix-list', ntype, asn, nid, neighbor) }}
{% endif %}
{% if neighbor['_prefix6'] | length %}
    if net.type = NET_IP6 && !(net ~ [ {{ neighbor['_prefix6'] | join(', ') }} ]) then {{ filtered_reject('prefix-list', ntype, asn, nid, neighbor) }}
{% else %}
    if net.type = NET_IP6 then {{ filtered_reject('prefix-list', ntype, asn, nid, neighbor) }}
{% endif %}
{% endif %}
    if !blackhole_triggered then {
{% if irr_cone %}
      if !autogen_as{{ asn }}_validate_path() then {{ filtered_reject('as-path', ntype, asn, nid, neighbor) }}
{% endif %}
{% if not neighbor._no_in_filter %}
{% if ntype == 'IBGP' %}
      if !autogen_filter_ibgp() then {{ filtered_reject('ibgp', ntype, asn, nid, neighbor) }}
{% else %}
{% if not neighbor['_asn_public'] %}
      # private ASN: its private ASNs are stripped from the as-path in the
      # attr section below.
{% endif %}
      ebgp_reject_reason = autogen_filter_ebgp();
      if ebgp_reject_reason != "" then {{ filtered_reject_var('ebgp_reject_reason', ntype, asn, nid, neighbor) }}
{% endif %}
{% endif %}
    }
  }
  # post import filter
{% if neighbor['post-import-filter'] %}
{{ neighbor['post-import-filter'] | trim | indent(2, true) }}
{% endif %}

  # attr
  if blackhole_triggered then dest = RTD_BLACKHOLE;
{% if not neighbor._no_in_filter and neighbor['_asn_public'] %}
  autogen_{{ ntype | lower }}_attrs();
{% endif %}
{% if not neighbor['_asn_public'] %}
  # Strip the customer's private ASNs from the as-path so they never leak.
  bgp_path.delete(autogen_private_asns);
{% endif %}
{% if neighbor['local-pref'] %}
  bgp_local_pref = {{ neighbor['local-pref'] }};
{% endif %}
{% if neighbor._med %}
{% if neighbor._med.mode == 'add' or neighbor._med.mode == 'sub' %}
  # Adjust relative to the current MED. The else covers neighbors where
  # autogen_*_attrs never ran (no-in-filter), so we fall back to default_med.
{% if neighbor._med.mode == 'add' %}
  if defined(bgp_med) then bgp_med = bgp_med + {{ neighbor._med.value }};
  else bgp_med = default_med + {{ neighbor._med.value }};
{% else %}
  if defined(bgp_med) then bgp_med = bgp_med - {{ neighbor._med.value }};
  else bgp_med = default_med - {{ neighbor._med.value }};
{% endif %}
{% else %}
  bgp_med = {{ neighbor._med.value }};
{% endif %}
{% endif %}
{% if neighbor._in_prepend %}
{% for p_asn in neighbor._in_prepend %}
  bgp_path.prepend({{ p_asn }});
{% endfor %}
{% endif %}
{% if ntype != 'IBGP' %}
  bgp_large_community.add(large_community_from_as({{ asn }}));
{% endif %}
  bgp_large_community.add(large_community_from_neighbor_id({{ nid }}));

  # pre import accept
{% if neighbor['pre-import-accept'] %}
{{ neighbor['pre-import-accept'] | indent(2, true) }}
{% endif %}
  accept;
}

{% set is_simple = neighbor._is_simple %}
filter {{ filter_prefix }}_out {
  bool blackhole_triggered = check_blackhole();
{% if ntype != 'IBGP' %}
  string ebgp_reject_reason = "";
{% endif %}
  # pre export filter

  # export filter
{% if ntype == 'IBGP' %}
  # iBGP is internal — no route-leak risk here (the directional no-leak gate is
  # enforced at every router's eBGP egress). The whole filter stays skippable so
  # a blackhole propagates internally for network-wide RTBH.
  if !blackhole_triggered then {
{% if is_simple %}
    if !autogen_simple_ibgp_out() then reject;
{% else %}
    if !autogen_ibgp_out() then reject;
{% endif %}
  }
{% else %}
  # The directional / no-leak gate ALWAYS runs — even a blackhole must obey
  # valley-free routing (an upstream-learned route, even blackholed, must never
  # be re-advertised to another upstream/peer/route-server).
  if !autogen_{{ ntype | lower }}_out() then reject;
  # Content hygiene (bogons / RPKI / blacklist) is skipped for blackhole routes:
  # a /32 blackhole would otherwise be RPKI-invalid (more-specific than its ROA)
  # and dropped.
  if !blackhole_triggered then {
    ebgp_reject_reason = autogen_filter_ebgp();
    if ebgp_reject_reason != "" then {{ filtered_reject_var('ebgp_reject_reason', ntype, asn, nid, neighbor, 'EXPORT-FILTERED') }}
  }
{% endif %}

  # export control communities
{% if neighbor['_asn_public'] and not is_simple %}
  # DNA (do-not-announce): drop if tagged not-to-anyone / not-to-this-AS / -nid
  if (bgp_large_community ~ large_community_dna_any) || (large_community_do_not_announce_to_as({{ asn }}) ~ bgp_large_community) || (large_community_do_not_announce_to_neighbor_id({{ nid }}) ~ bgp_large_community) then reject;
  # OLA (only-announce): drop if it carries an OLA community but none for this AS/nid
  if (bgp_large_community ~ large_community_ola_all) && !((large_community_only_announce_to_as({{ asn }}) ~ bgp_large_community) || (large_community_only_announce_to_neighbor_id({{ nid }}) ~ bgp_large_community)) then reject;
{% endif %}
  # post export filter

  # attr
{% if not is_simple and neighbor._out_prepend %}
{% for p_asn in neighbor._out_prepend %}
  bgp_path.prepend({{ p_asn }});
{% endfor %}
{% endif %}
{% if not is_simple and neighbor['_asn_public'] %}
  autogen_apply_prepend_to_as({{ asn }});
{% endif %}
  # pre export accept
{% if not is_simple and neighbor['pre-export-accept'] %}
{{ neighbor['pre-export-accept'] | indent(2, true) }}
{% endif %}
  accept;
}
{% endmacro %}

{% macro render_neighbor_protocol(ntype, neighbor) %}
{% set asn = neighbor._asn %}
{% set nid = neighbor.nid %}
{% set proto_base = neighbor._proto_base %}
{% set filter_prefix = neighbor._filter_prefix %}
{% set is_shutdown = neighbor._is_shutdown %}
{% set mp_in = neighbor._mp_in %}
{% set mp_out = neighbor._mp_out %}
{% if neighbor._dyn %}
{# Dynamic BGP. `_range` => listen for incoming peers in that prefix. An
   `_unnumbered_iface` => auto unnumbered: a per-neighbor RAdv discovers the
   peer's link-local into `unnumbered_<base>`, and the dynamic BGP peers over
   fe80::/64. Spawned sessions inherit the parent channels' filters. #}
{% set unnum = neighbor._dyn.unnum %}
{% if unnum %}
neighbor table unnumbered_{{ proto_base }};
protocol radv radv_{{ proto_base }} {
{% if neighbor['_vrf'] %}
  vrf "{{ neighbor['_vrf'].name }}";
{% endif %}
  neighbors { table unnumbered_{{ proto_base }}; };
  interface "{{ unnum }}" { router discovery yes; };
}
{% endif %}
protocol bgp {{ proto_base }} {
  description "{{ neighbor._desc_proto }}";
{% if neighbor['_vrf'] %}
  vrf "{{ neighbor['_vrf'].name }}";
{% endif %}
  local as {{ neighbor._local_as }};
  neighbor range {{ neighbor._dyn.rng }} as {{ asn }};
{% if unnum %}
  # Pin link-local sessions to this interface. Without it, multiple unnumbered
  # roots all carry the same `neighbor range fe80::/64` and BIRD can't tell
  # which interface an incoming/discovered fe80:: peer belongs to (a hub with
  # several unnumbered peers would mis-dispatch or drop them).
  interface "{{ unnum }}";
{% endif %}
  dynamic name "{{ proto_base }}_";
  dynamic name digits 2;
{% if unnum or not neighbor.multihop %}
  # On-link session. Must be explicit: iBGP defaults to multihop, which cannot
  # resolve a route to a link-local (fe80::) neighbor, so the spawned dynamic
  # sessions would never establish.
  direct;
{% else %}
  multihop {{ neighbor.multihop }};
{% endif %}
{% if is_shutdown %}
  disabled;
{% endif %}
{% if neighbor.passive %}
  passive on;
{% endif %}
{% if neighbor.password %}
  password "{{ neighbor.password }}";
{% endif %}
  graceful restart on;
{% if neighbor._dyn.want4 %}

  ipv4 {
{% if neighbor['_vrf'] %}
    table vrf_{{ neighbor['_vrf'].id }}_v4;
{% endif %}
    import filter {{ filter_prefix }}_in;
{% if neighbor._keep_filtered %}
    import keep filtered on;
{% endif %}
{% if neighbor['default-originate'] %}
    export filter { if net = 0.0.0.0/0 then accept; reject; };
{% else %}
    export filter {{ filter_prefix }}_out;
{% endif %}
    next hop self;
{% if unnum or neighbor._dyn.rng_v6 or neighbor['extended-nexthop'] %}
    # RFC 8950: accept IPv4 NLRI with an IPv6 next hop (session runs over IPv6).
    extended next hop;
{% endif %}
{% if ntype in ['Peer', 'Downstream'] %}
    import limit {{ mp_in[0] }} action disable;
{% endif %}
{% if ntype in ['Upstream', 'RouteServer', 'Peer'] %}
    export limit {{ mp_out[0] }} action disable;
{% endif %}
{% if neighbor.addpath %}
    add paths tx;
{% endif %}
  };
{% endif %}
{% if neighbor._dyn.want6 %}

  ipv6 {
{% if neighbor['_vrf'] %}
    table vrf_{{ neighbor['_vrf'].id }}_v6;
{% endif %}
    import filter {{ filter_prefix }}_in;
{% if neighbor._keep_filtered %}
    import keep filtered on;
{% endif %}
{% if neighbor['default-originate'] %}
    export filter { if net = ::/0 then accept; reject; };
{% else %}
    export filter {{ filter_prefix }}_out;
{% endif %}
    next hop self;
{% if ntype in ['Peer', 'Downstream'] %}
    import limit {{ mp_in[1] }} action disable;
{% endif %}
{% if ntype in ['Upstream', 'RouteServer', 'Peer'] %}
    export limit {{ mp_out[1] }} action disable;
{% endif %}
{% if neighbor.addpath %}
    add paths tx;
{% endif %}
  };
{% endif %}
{% if unnum %}
  neighbors { table unnumbered_{{ proto_base }}; export all; };
{% endif %}
}
{% else %}
{# Each neighbor address becomes its own `protocol bgp`. The _v4/_v6 suffix
   reflects the PEER ADDRESS family (is_v6), not the address-family/channels:
   a v4-peer or v6-peer session can still carry both ipv4 and ipv6 channels
   (see want4/want6 below, driven by `address-family` / `extended-nexthop`).
   Naming: <base>_v4 / <base>_v6; an extra _N is appended only when one family
   has more than one address (e.g. two v4 peers -> _v4_1, _v4_2). Splitting per
   address also guarantees source-address family always matches its channel. #}
{% for ap in neighbor._addr_protos %}

protocol bgp {{ ap.proto_name }} {
  description "{{ neighbor._desc_proto }}";
{% if neighbor['_vrf'] %}
  vrf "{{ neighbor['_vrf'].name }}";
{% endif %}
  local as {{ neighbor._local_as }};
  neighbor {{ ap.addr }} as {{ asn }};
{% if ap.src_match %}
  source address {{ neighbor['_source_address'] }};
{% endif %}
{% if is_shutdown %}
  disabled;
{% endif %}
{% if neighbor.passive %}
  passive on;
{% endif %}
{% if neighbor.password %}
  password "{{ neighbor.password }}";
{% endif %}
{% if neighbor.multihop %}
  multihop {{ neighbor.multihop }};
{% else %}
  direct;
{% endif %}
{% if neighbor.holdtime %}
  hold time {{ neighbor.holdtime }};
{% endif %}
{% if neighbor.keepalive %}
  keepalive time {{ neighbor.keepalive }};
{% endif %}
  graceful restart on;
{% if ap.want4 %}

  ipv4 {
{% if neighbor['_vrf'] %}
    table vrf_{{ neighbor['_vrf'].id }}_v4;
{% endif %}
    import filter {{ filter_prefix }}_in;
{% if neighbor._keep_filtered %}
    import keep filtered on;
{% endif %}
{% if neighbor['default-originate'] %}
    export filter { if net = 0.0.0.0/0 then accept; reject; };
{% else %}
    export filter {{ filter_prefix }}_out;
{% endif %}
    next hop self;
{% if neighbor['extended-nexthop'] %}
    # RFC 8950: accept IPv4 NLRI with an IPv6 next hop (unnumbered / v4-over-v6).
    # Must be on the IPv4 channel; the session itself runs over IPv6.
    extended next hop;
{% endif %}
{% if ntype in ['Peer', 'Downstream'] %}
    import limit {{ mp_in[0] }} action disable;
{% endif %}
{% if ntype in ['Upstream', 'RouteServer', 'Peer'] %}
    export limit {{ mp_out[0] }} action disable;
{% endif %}
{% if neighbor.addpath %}
    add paths tx;
{% endif %}
  };
{% endif %}
{% if ap.want6 %}

  ipv6 {
{% if neighbor['_vrf'] %}
    table vrf_{{ neighbor['_vrf'].id }}_v6;
{% endif %}
    import filter {{ filter_prefix }}_in;
{% if neighbor._keep_filtered %}
    import keep filtered on;
{% endif %}
{% if neighbor['default-originate'] %}
    export filter { if net = ::/0 then accept; reject; };
{% else %}
    export filter {{ filter_prefix }}_out;
{% endif %}
    next hop self;
{% if ntype in ['Peer', 'Downstream'] %}
    import limit {{ mp_in[1] }} action disable;
{% endif %}
{% if ntype in ['Upstream', 'RouteServer', 'Peer'] %}
    export limit {{ mp_out[1] }} action disable;
{% endif %}
{% if neighbor.addpath %}
    add paths tx;
{% endif %}
  };
{% endif %}
}
{% endfor %}
{% endif %}
{% endmacro %}
# Rendering Session Filters
{# _render_neighbors is the flat (ntype, neighbor) list built by _prepare_for_bird,
   covering the default context AND every VRF, in render order. #}
{% for ntype, n in router_config['_render_neighbors'] %}{{ render_neighbor_filters(ntype, n) }}{% endfor %}

# Rendering Protocol Instances
{% for ntype, n in router_config['_render_neighbors'] %}{{ render_neighbor_protocol(ntype, n) }}{% endfor %}
